<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Squiggle.UI.Avalonia.App">
    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
    <Application.Resources>
        <ResourceInclude Source="avares://Squiggle.UI.Avalonia/Styles/AppStyles.axaml" />
        <ResourceInclude Source="avares://Squiggle.UI.Avalonia/Styles/Translations.axaml" />
    </Application.Resources>
</Application>
