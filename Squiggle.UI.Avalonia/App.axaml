<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Squiggle.UI.Avalonia.App">
    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Squiggle.UI.Avalonia/Styles/AppStyles.axaml" />
    </Application.Styles>
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://Squiggle.UI.Avalonia/Styles/Translations.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
